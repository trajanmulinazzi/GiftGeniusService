# Postgres connection (optional - defaults match docker-compose)
# Use DATABASE_URL or individual vars:
DATABASE_URL=postgresql://giftgenius:giftgenius@localhost:5432/giftgenius

# Or:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=giftgenius
# PGPASSWORD=giftgenius
# PGDATABASE=giftgenius

# Canopy API - Amazon product search (for ingest --canopy, 100 free calls/month)
# Sign up at https://www.canopyapi.co
CANOPY_API_KEY=your-canopy-api-key

# Amazon Creators API (for ingest --amazon, when you have 10 sales/30d)
# Get credentials from Amazon Associates / Creators API
# AMAZON_PARTNER_TAG = your Store ID (e.g. tealdresser03-20)
AMAZON_CREDENTIAL_ID=your-credential-id
AMAZON_CREDENTIAL_SECRET=your-credential-secret
AMAZON_PARTNER_TAG=tealdresser03-20
# Optional: 2.1 (NA), 2.2 (EU), 2.3 (FE). Default 2.1
# AMAZON_CREDENTIAL_VERSION=2.1
# Optional: default www.amazon.com
# AMAZON_MARKETPLACE=www.amazon.com
