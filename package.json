  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node index.js",
    "start:api": "node server.js",
    "ingest": "node scripts/ingest-catalog.js",
    "ingest:amazon": "node scripts/ingest-catalog.js --amazon",
    "ingest:canopy": "node scripts/ingest-catalog.js --canopy",
    "ingest:canopy-product": "node scripts/ingest-catalog.js --canopy-product",
    "update-affiliate-links": "node scripts/update-affiliate-links.js",
    "list-catalog": "node scripts/list-catalog.js",
    "list-queue": "node scripts/list-queue.js",
    "amazon:response": "node scripts/amazon-api-response.js",
    "amazon:item-response": "node scripts/amazon-item-response.js",
    "canopy:response": "node scripts/canopy-api-response.js",
    "canopy:search-to-catalog": "node scripts/canopy-search-to-catalog.js",
    "db:migrate": "docker exec -i giftgenius-postgres psql -U giftgenius -d giftgenius < db/schema.pg.sql"
  },
  "dependencies": {
    "@amzn/creatorsapi-nodejs-sdk": "file:../creatorsapi-nodejs-sdk",
    "@clack/prompts": "^1.0.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.8.5",
    "pg": "^8.18.0"
  }
}
